.DS_Store
.env
.env.*
!.env.example
.venv/
__pycache__/
*.pyc
*.pyo
node_modules/
*.log
_run.log
_run.pid
.pytest_cache/
.ruff_cache/
.embedder/
minion_logs/

# --- results ---
# Ignore all intermediate per-run state under results/, but explicitly keep
# the shippable report artefacts (REPORT.md, DECISION_MATRIX.md, *.png)
# per-dated-folder. If we want to ship a run publicly, the REPORT and
# charts below are the trackable pieces.
results/
!results/README.md
!results/**/REPORT.md
!results/**/DECISION_MATRIX.md
!results/**/*.png
!results/**/*.svg

# --- vendored reference clones (treated as read-only vendored deps) ---
# Pre-reorg path kept for branches still on the old layout.
EXTERNAL/minions/
EXTERNAL/*/.git/
vendor/minions/
vendor/*/.git/

# --- router telemetry ---
# decisions.jsonl + all other router logs grow on every request. Everything
# is local-only; the historical log is preserved by the run datasets under
# results/runs/<sweep>/router-decisions.jsonl as needed.
router/logs/*.jsonl
*.egg-info/

# --- in-progress files (private to the working developer) ---
.aider.chat.history.md
.aider.input.history
.claude/

# v3.3 sweep + scripts logs — track INDEX.md as the canonical pointer; ignore the rest.
logs/
!logs/v3.3/
!logs/v3.3/INDEX.md

# Owner's personal working material (article, appendices, charts, HTML report).
# Not part of the OSS surface — kept here for the article publication workflow.
personal/
