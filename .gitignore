.DS_Store
.env
.env.*
!.env.example
.venv/
__pycache__/
*.pyc
*.pyo
node_modules/
*.log
_run.log
_run.pid
.pytest_cache/

# --- results ---
# Ignore all intermediate per-run state under results/, but explicitly keep
# the shippable report artefacts (REPORT.md, DECISION_MATRIX.md, *.png)
# per-dated-folder. If we want to ship a run publicly, the REPORT and
# charts below are the trackable pieces.
results/
!results/README.md
!results/**/REPORT.md
!results/**/DECISION_MATRIX.md
!results/**/*.png
!results/**/*.svg

# --- vendored reference clones (treated as read-only vendored deps) ---
# Pre-reorg path kept for branches still on the old layout.
EXTERNAL/minions/
EXTERNAL/*/.git/
vendor/minions/
vendor/*/.git/

# --- router telemetry ---
# decisions.jsonl grows on every request. New churn not committed; the
# historical log is already tracked and stays as reference.
router/logs/*.jsonl
!router/logs/decisions.jsonl
